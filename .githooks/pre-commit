#!/usr/bin/env sh
set -eu

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/check-index-sync.ps1
elif command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-index-sync.ps1
else
  echo "ERROR: PowerShell was not found. Cannot run index/index_formulas sync check." >&2
  exit 1
fi
